{
  "name": "arena-oracle",
  "productName": "Arena Oracle",
  "version": "0.0.0",
  "description": "AI coaching assistant for Magic: The Gathering Arena",
  "main": ".vite/build/main.js",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^25.0.0",
    "pnpm": "^10.33.0"
  },
  "scripts": {
    "native:node": "pnpm rebuild better-sqlite3",
    "native:electron": "electron-rebuild -f -w better-sqlite3",
    "start": "pnpm run native:electron && electron-forge start",
    "package": "pnpm run native:electron && electron-forge package",
    "make": "pnpm run native:electron && electron-forge make",
    "publish": "pnpm run native:electron && electron-forge publish",
    "clean": "rimraf out .vite .tsbuild coverage test-results node_modules",
    "check": "tsc -b",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "pnpm run native:node && vitest",
    "test:ui": "pnpm run native:node && vitest --ui",
    "test:cov": "pnpm run native:node && vitest --coverage",
    "test:ci": "pnpm run native:node && vitest --run --coverage",
    "pretest:e2e": "pnpm run package",
    "test:e2e": "playwright test",
    "pretest:e2e:ui": "pnpm run package",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": {
    "name": "andgate",
    "email": "the.andgate@gmail.com"
  },
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "keytar",
      "msw"
    ]
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.31",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@types/better-sqlite3": "^7.6.13",
    "ai": "^6.0.142",
    "better-sqlite3": "12.8.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "immer": "^11.1.4",
    "keytar": "^7.9.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-scrollable-feed": "^2.0.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tsyringe": "^4.10.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.59.0",
    "@tanstack/eslint-plugin-query": "^5.96.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "4.1.2",
    "electron": "41.1.0",
    "eslint": "^10.1.0",
    "flora-colossus": "^3.0.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "memfs": "^4.57.1",
    "nodemon": "^3.1.14",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "7.3.1",
    "vitest": "4.1.2"
  }
}
