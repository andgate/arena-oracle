{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "..",
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2021"
    ],
    "outDir": "../.tsbuild/main",
    "tsBuildInfoFile": "../.tsbuild/main/tsconfig.main.tsbuildinfo",
    "types": [
      "node",
      "vitest/globals"
    ],
    // Required by tsyringe
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ],
  "include": [
    "../src/main/**/*",
    "../tests/main/**/*",
    "../tests/e2e/**/*"
  ],
  "exclude": [
    "../src/main/**/*.spec.ts"
  ]
}