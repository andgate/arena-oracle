{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "..",
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2021"
    ],
    "outDir": "../.tsbuild/shared-tests",
    "tsBuildInfoFile": "../.tsbuild/shared-tests/tsconfig.shared-tests.tsbuildinfo",
    "types": [
      "node",
      "vitest/globals"
    ],
  },
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ],
  "include": [
    "../src/shared/**/*.spec.ts"
  ]
}