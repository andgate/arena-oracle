{
  "compilerOptions": {
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@main/*": [
        "../src/main/*"
      ],
      "@renderer/*": [
        "../src/renderer/*"
      ],
      "@shared/*": [
        "../src/shared/*"
      ],
      "@tests/*": [
        "../tests/*"
      ]
    }
  }
}