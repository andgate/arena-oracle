{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "../src/renderer",
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "outDir": "../.tsbuild/renderer",
    "tsBuildInfoFile": "../.tsbuild/renderer/tsconfig.renderer.tsbuildinfo",
    "types": [
      "vite/client"
    ]
  },
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ],
  "include": [
    "../src/renderer/**/*"
  ]
}
